#!/bin/bash
set -euo pipefail

URL="${FIGMA_MAKE_URL:-http://localhost:${PORT:-3000}}"
TRIES=30
DELAY=2

for i in $(seq 1 $TRIES); do
  STATUS=$(curl -so /dev/null -w '%{http_code}' "$URL" 2>/dev/null || true)
  if [ -n "$STATUS" ] && [ "$STATUS" != "000" ]; then
    echo "Dev server is ready at $URL (HTTP $STATUS)"
    exit 0
  fi
  sleep $DELAY
done

echo "Dev server did not respond at $URL after $((TRIES * DELAY))s"
exit 1
